DATABASE_URL=sqlite:///./data/kubemind.db
CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
LOG_LEVEL=INFO
DEBUG=true

# DeepSeek (optional)
DEEPSEEK_MODEL_NAME=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_AUTH_TOKEN=

# Kubernetes (optional)
KUBECONFIG_PATH=./app/config/kubeconfig.yaml

# Vector DB (Milvus)
VECTOR_DB_TYPE=milvus
VECTOR_DB_HOST=127.0.0.1
VECTOR_DB_PORT=19530
VECTOR_DB_USER=root
VECTOR_DB_PASSWORD=
VECTOR_DB_COLLECTION_NAME=kubemind_docs

#promethues
PROMETHEUS_HOST=127.0.0.1
PROMETHEUS_PORT=30090
PROMETHEUS_API_KEY=

# Loki
LOKI_HOST=127.0.0.1
LOKI_PORT=3100
LOKI_API_KEY=

